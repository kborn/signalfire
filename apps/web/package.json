{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "pnpm --filter @signal-fire/api-contracts build && pnpm --filter @signal-fire/admin-auth-shared build",
    "dev": "next dev",
    "prelint": "pnpm --filter @signal-fire/api-contracts build && pnpm --filter @signal-fire/admin-auth-shared build",
    "prebuild": "pnpm --filter @signal-fire/api-contracts build && pnpm --filter @signal-fire/admin-auth-shared build",
    "build": "next build",
    "prestart": "pnpm --filter @signal-fire/api-contracts build && pnpm --filter @signal-fire/admin-auth-shared build",
    "start": "next start",
    "lint": "eslint",
    "pretest": "pnpm --filter @signal-fire/api-contracts build && pnpm --filter @signal-fire/admin-auth-shared build",
    "test": "vitest run",
    "pretest:watch": "pnpm --filter @signal-fire/api-contracts build && pnpm --filter @signal-fire/admin-auth-shared build",
    "test:watch": "vitest",
    "pretypecheck": "pnpm --filter @signal-fire/api-contracts build && pnpm --filter @signal-fire/admin-auth-shared build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@signal-fire/admin-auth-shared": "workspace:*",
    "@signal-fire/api-contracts": "workspace:*",
    "next": "16.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-import": "^2.32.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
