{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "pnpm --filter @signal-fire/api-contracts build",
    "dev": "next dev",
    "prelint": "pnpm --filter @signal-fire/api-contracts build",
    "prebuild": "pnpm --filter @signal-fire/api-contracts build",
    "build": "next build",
    "prestart": "pnpm --filter @signal-fire/api-contracts build",
    "start": "next start",
    "lint": "eslint",
    "pretest": "pnpm --filter @signal-fire/api-contracts build",
    "test": "vitest run",
    "pretest:watch": "pnpm --filter @signal-fire/api-contracts build",
    "test:watch": "vitest",
    "pretypecheck": "pnpm --filter @signal-fire/api-contracts build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@signal-fire/api-contracts": "workspace:*",
    "next": "16.2.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-import": "^2.32.0",
    "jsdom": "^29.0.2",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
