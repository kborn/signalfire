// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SubmissionType {
  EVENT
  ARTICLE

  @@map("submission_type")
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("submission_status")
}

enum EntityStatus {
  DRAFT
  PUBLISHED

  @@map("entity_status")
}

enum ActionType {
  GUIDE
  LINK
  CONTACT
  DONATE
  VOLUNTEER

  @@map("action_type")
}

enum EventType {
  PROTEST
  RALLY
  VOLUNTEER
  TOWN_HALL
  WORKSHOP
  MEETING

  @@map("event_type")
}

model Topic {
  id   Int    @id @default(autoincrement())
  slug String @unique
  name String

  description      String
  createdAt        DateTime          @default(now()) @map("created_at")
  topicArticles    TopicArticle[]
  topicActions     TopicAction[]
  topicEvents      TopicEvent[]
  submissionTopics SubmissionTopic[]

  @@map("topic")
}

model Article {
  id             Int             @id @default(autoincrement())
  slug           String          @unique
  title          String
  summary        String
  content        String
  status         EntityStatus
  author         String
  createdAt      DateTime        @default(now()) @map("created_at")
  publishedAt    DateTime?       @map("published_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  submission     Submission?
  topicArticles  TopicArticle[]
  articleActions ArticleAction[]
  articleEvents  ArticleEvent[]

  @@map("article")
}

model Action {
  id             Int             @id @default(autoincrement())
  slug           String          @unique
  title          String
  summary        String
  description    String
  actionType     ActionType      @map("action_type")
  status         EntityStatus
  createdAt      DateTime        @default(now()) @map("created_at")
  publishedAt    DateTime?       @map("published_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  topicActions   TopicAction[]
  articleActions ArticleAction[]
  actionEvents   ActionEvent[]

  @@map("action")
}

model Event {
  id                        Int            @id @default(autoincrement())
  title                     String
  summary                   String
  description               String
  website                   String?
  contactEmail              String?        @map("contact_email")
  eventType                 EventType      @map("event_type")
  status                    EntityStatus
  startTime                 DateTime       @map("start_time")
  endTime                   DateTime?      @map("end_time")
  locationName              String         @map("location_name")
  publicLocationDescription String?        @map("public_location_description")
  addressLine1              String?        @map("address_line1")
  addressLine2              String?        @map("address_line2")
  city                      String?
  region                    String?
  postalCode                String?        @map("postal_code")
  country                   String?
  latitude                  Decimal?
  longitude                 Decimal?
  submission                Submission?
  createdAt                 DateTime       @default(now()) @map("created_at")
  publishedAt               DateTime?      @map("published_at")
  updatedAt                 DateTime       @updatedAt @map("updated_at")
  topicEvents               TopicEvent[]
  articleEvents             ArticleEvent[]
  actionEvents              ActionEvent[]

  @@map("event")
}

model Submission {
  id                        Int                      @id @default(autoincrement())
  submissionType            SubmissionType           @map("submission_type")
  status                    SubmissionStatus
  title                     String
  summary                   String
  submittedContent          String                   @map("submitted_content")
  author                    String?
  submitterName             String?                  @map("submitter_name")
  submitterEmail            String?                  @map("submitter_email")
  eventType                 EventType?               @map("event_type")
  startTime                 DateTime?                @map("start_time")
  endTime                   DateTime?                @map("end_time")
  locationName              String?                  @map("location_name")
  publicLocationDescription String?                  @map("public_location_description")
  addressLine1              String?                  @map("address_line1")
  addressLine2              String?                  @map("address_line2")
  city                      String?
  region                    String?
  postalCode                String?                  @map("postal_code")
  country                   String?
  website                   String?
  contactEmail              String?                  @map("contact_email")
  reviewNotes               String?                  @map("review_notes")
  article                   Article?                 @relation(fields: [articleId], references: [id])
  articleId                 Int?                     @unique @map("article_id")
  event                     Event?                   @relation(fields: [eventId], references: [id])
  eventId                   Int?                     @unique @map("event_id")
  submissionResourceLinks   SubmissionResourceLink[]
  submissionTopics          SubmissionTopic[]
  submittedAt               DateTime                 @default(now()) @map("submitted_at")
  reviewedAt                DateTime?                @map("reviewed_at")

  @@map("submission")
}

model ResourceLink {
  id                      Int                      @id @default(autoincrement())
  url                     String                   @unique
  submissionResourceLinks SubmissionResourceLink[]
  created                 DateTime                 @default(now()) @map("created_at")

  @@map("resource_link")
}

model TopicArticle {
  topic      Topic    @relation(fields: [topicId], references: [id])
  topicId    Int      @map("topic_id")
  article    Article  @relation(fields: [articleId], references: [id])
  articleId  Int      @map("article_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String   @map("assigned_by")

  @@id([topicId, articleId])
  @@map("topic_article")
}

model TopicAction {
  topic      Topic    @relation(fields: [topicId], references: [id])
  topicId    Int      @map("topic_id")
  action     Action   @relation(fields: [actionId], references: [id])
  actionId   Int      @map("action_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String   @map("assigned_by")

  @@id([topicId, actionId])
  @@map("topic_action")
}

model TopicEvent {
  topic      Topic    @relation(fields: [topicId], references: [id])
  topicId    Int      @map("topic_id")
  event      Event    @relation(fields: [eventId], references: [id])
  eventId    Int      @map("event_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String   @map("assigned_by")

  @@id([topicId, eventId])
  @@map("topic_event")
}

model ArticleAction {
  article    Article  @relation(fields: [articleId], references: [id])
  articleId  Int      @map("article_id")
  action     Action   @relation(fields: [actionId], references: [id])
  actionId   Int      @map("action_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String   @map("assigned_by")

  @@id([articleId, actionId])
  @@map("article_action")
}

model ArticleEvent {
  article    Article  @relation(fields: [articleId], references: [id])
  articleId  Int      @map("article_id")
  event      Event    @relation(fields: [eventId], references: [id])
  eventId    Int      @map("event_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String   @map("assigned_by")

  @@id([articleId, eventId])
  @@map("article_event")
}

model ActionEvent {
  action     Action   @relation(fields: [actionId], references: [id])
  actionId   Int      @map("action_id")
  event      Event    @relation(fields: [eventId], references: [id])
  eventId    Int      @map("event_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String   @map("assigned_by")

  @@id([actionId, eventId])
  @@map("action_event")
}

model SubmissionTopic {
  submission   Submission @relation(fields: [submissionId], references: [id])
  submissionId Int        @map("submission_id")
  topic        Topic      @relation(fields: [topicId], references: [id])
  topicId      Int        @map("topic_id")
  assignedAt   DateTime   @default(now()) @map("assigned_at")

  @@id([submissionId, topicId])
  @@map("submission_topic")
}

model SubmissionResourceLink {
  submission     Submission   @relation(fields: [submissionId], references: [id])
  submissionId   Int          @map("submission_id")
  resourceLink   ResourceLink @relation(fields: [resourceLinkId], references: [id])
  resourceLinkId Int          @map("resource_link_id")
  assignedAt     DateTime     @default(now()) @map("assigned_at")

  @@id([submissionId, resourceLinkId])
  @@map("submission_resource_link")
}

model AdminUser {
  id           Int            @id @default(autoincrement())
  email        String         @unique
  passwordHash String         @map("password_hash")
  isActive     Boolean        @default(true) @map("is_active")
  sessions     AdminSession[]
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@map("admin_user")
}

model AdminSession {
  id           Int       @id @default(autoincrement())
  sessionToken String    @unique @map("session_token")
  adminUser    AdminUser @relation(fields: [adminUserId], references: [id])
  adminUserId  Int       @map("admin_user_id")
  expiresAt    DateTime  @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  lastUsedAt   DateTime  @default(now()) @map("last_used_at")

  @@map("admin_session")
}
