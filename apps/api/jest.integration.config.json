{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "test",
  "testRegex": ".*\\.intg-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@signal-fire/admin-auth-shared$": "<rootDir>/../../packages/admin-auth-shared/index.ts",
    "^@signal-fire/api-contracts$": "<rootDir>/../../packages/api-contracts/index.ts"
  },
  "collectCoverageFrom": ["**/*.(t|j)s"],
  "coverageDirectory": "../coverage",
  "testEnvironment": "<rootDir>/intg-config/prisma-pg.environment.js",
  "globalSetup": "<rootDir>/intg-config/globalSetup.js",
  "globalTeardown": "<rootDir>/intg-config/globalTeardown.js",
  "setupFilesAfterEnv": ["<rootDir>/jest.setup.ts"]
}
