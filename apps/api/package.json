{
  "name": "api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prelint": "pnpm --filter @signal-fire/api-contracts build && pnpm --filter @signal-fire/admin-auth-shared build",
    "prebuild": "pnpm --filter @signal-fire/api-contracts build && pnpm --filter @signal-fire/admin-auth-shared build",
    "build": "nest build",
    "dev": "nest start --watch",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:seed": "prisma db seed",
    "prisma:migrate:seed:demo": "SEED_MODE=demo prisma db seed",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "pnpm test:unit",
    "test:unit": "jest --config ./jest.unit.config.json",
    "test:integration": "jest --config ./jest.integration.config.json --runInBand",
    "pretest:e2e": "pnpm --filter @signal-fire/api-contracts build && pnpm --filter @signal-fire/admin-auth-shared build",
    "test:unit:watch": "pnpm test:unit --watch",
    "test:unit:cov": "pnpm test:unit --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --config ./jest.unit.config.json --runInBand",
    "test:e2e": "jest --config ./jest.e2e.config.json --runInBand",
    "pretypecheck": "pnpm --filter @signal-fire/api-contracts build && pnpm --filter @signal-fire/admin-auth-shared build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@signal-fire/admin-auth-shared": "workspace:*",
    "@signal-fire/api-contracts": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/testing": "^11.1.27",
    "@playwright/test": "^1.61.0",
    "@quramy/jest-prisma": "^1.8.2",
    "@quramy/jest-prisma-core": "^1.8.2",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.21",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "axios": "^1.18.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^16.5.0",
    "jest": "^30.4.2",
    "prettier": "^3.9.3",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1"
  }
}
